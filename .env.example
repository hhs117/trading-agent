DATABASE_URL=
BOOTSTRAP_TOKEN=
AI_PROVIDER=deepseek
AI_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
# 全网查品数据源模式：
#   auto         按平台路由 + 多源并行聚合（默认，推荐）
#   mock         返回内置示例数据，离线开发用
#   external     调用 PRODUCT_SEARCH_API_URL 指向的自建/聚合服务
#   rainforest   只走 Amazon (Rainforest)
#   zhixia       只走 Shopee / Lazada (知虾)
#   fastmoss     只走 TikTok Shop (FastMoss)
#   apify        只走 Temu (Apify Actor)
PRODUCT_SEARCH_PROVIDER=auto
PRODUCT_SEARCH_API_URL=
PRODUCT_SEARCH_API_KEY=
# Amazon 实时数据（Rainforest API；auto 模式下自动启用）
RAINFOREST_API_KEY=
RAINFOREST_AMAZON_DOMAIN=amazon.com

# Optional third-party integrations for later phases.
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_REDIRECT_URL=
SHOPEE_API_BASE_URL=https://partner.shopeemobile.com
SHOPEE_AUTH_BASE_URL=https://partner.shopeemobile.com
# Backward-compatible aliases, if an older deployment already uses these names.
SHOPEE_CLIENT_ID=
SHOPEE_CLIENT_SECRET=
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_REDIRECT_URL=
TIKTOK_SHOP_API_BASE_URL=https://open-api.tiktokglobalshop.com
TIKTOK_SHOP_AUTH_BASE_URL=https://services.tiktokshop.com/open/authorize
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
LOGISTICS_API_KEY=

# 平台数据分析（/analytics）+ 全网查品 - 第三方市场数据源
# 同时给 /analytics 类目情报与 /search-products 全网查品（auto 模式）使用
# 知虾 ZhiXia（Shopee/Lazada，需企业版套餐 + 联系商务拿 Key）
ZHIXIA_API_KEY=
ZHIXIA_API_BASE_URL=
# FastMoss（TikTok Shop，需付费套餐 + 联系商务拿 Key）
FASTMOSS_API_KEY=
FASTMOSS_API_BASE_URL=
# Temu（Apify Actor；apify.com 注册账号拿 token，actor 在 Apify Store 选一个 Temu scraper）
# APIFY_TEMU_ACTOR_ID 支持 username/actor 或 username~actor 两种写法
APIFY_API_TOKEN=
APIFY_TEMU_ACTOR_ID=
APIFY_TEMU_COUNTRY=US
APIFY_TEMU_TIMEOUT_SECS=120
# Google Trends 默认开启，若要禁用设为 false
MARKET_INTEL_ENABLE_GOOGLE_TRENDS=true
# 国内开发机访问 Google Trends 需要走代理。Clash 默认端口 7890。
# 仅 Google Trends 用此代理；如部署到海外可不设。
# 也可改用通用变量 HTTPS_PROXY，效果一样。
GOOGLE_TRENDS_PROXY=
# HTTPS_PROXY=http://127.0.0.1:7890
